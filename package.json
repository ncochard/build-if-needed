{
  "name": "build-if-needed",
  "version": "0.2.0",
  "description": "Build your code, only if you need to...",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist",
    "bin",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "prebuild": "yarn lint",
    "build": "tsc",
    "watch": "tsc --watch",
    "lint": "eslint src --fix",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "author": "Nicolas Cochard (nicolas@cochard.co.uk)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ncochard/build-if-needed.git"
  },
  "bin": {
    "build-if-needed": "./bin/build-if-needed.js"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "cosmiconfig": "^9.0.2",
    "execa": "^9.6.1",
    "globby": "^16.2.0",
    "mkdirp": "^3.0.1",
    "throat": "^6.0.2"
  }
}
